(client.js → logic API)

import axios from "axios";

const baseURL = import.meta.env.VITE_API_URL || "http://localhost:8001";

const apiClient = axios.create({
  baseURL,
  timeout: 15000,
});

// Response interceptor
apiClient.interceptors.response.use(
  (response) => {
    // langsung ambil data
    return response.data;
  },
  (error) => {
    // ambil pesan error dari backend
    const message =
      error.response?.data?.detail ||
      error.response?.data?.message ||
      error.message ||
      "Unknown error";

    return Promise.reject(message);
  }
);

// API functions
export const getStudent = (nim) => {
  return apiClient.get(`/students/${nim}`);
};

export const getPredict = (nim) => {
  return apiClient.get(`/predict/${nim}`);
};

export const getStudents = (params) => {
  return apiClient.get("/students", { params });
};

export const getHealth = () => {
  return apiClient.get("/health");
};

export const postIPKTarget = (nim, payload) => {
  return apiClient.post(`/students/${nim}/ipk-target`, payload);
};

export default apiClient;
